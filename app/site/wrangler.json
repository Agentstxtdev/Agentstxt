{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "agents-txt-spec",
	"main": "./src/worker.ts",
	"compatibility_date": "2026-01-28",
	"compatibility_flags": [
		"nodejs_compat"
	],
	"assets": {
		"directory": "./dist",
		"binding": "ASSETS"
	},
	"kv_namespaces": [
		{ "binding": "SESSION", "id": "c782398569a84842aafe66164d5366b8" }
	],
	"services": [
		{
			"binding": "MCP",
			"service": "agents-txt-mcp-production"
		},
		{
			"binding": "AUTH",
			"service": "agents-txt-auth-production"
		}
	],
	"env": {
		"production": {
			"name": "agents-txt-site-production",
			"kv_namespaces": [
				{ "binding": "SESSION", "id": "c782398569a84842aafe66164d5366b8" }
			],
			"services": [
				{
					"binding": "MCP",
					"service": "agents-txt-mcp-production"
				},
				{
					"binding": "AUTH",
					"service": "agents-txt-auth-production"
				}
			]
		}
	}
}