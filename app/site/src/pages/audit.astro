---
import BaseLayout from '../layouts/BaseLayout.astro';
import NavRight from '../components/NavRight.astro';
import '../styles/global.css';
import { SPEC_VERSION } from '../config';
---

<BaseLayout
  title="Audit a site against the agents.txt spec"
  description="Audit any live site against the agents.txt specification. Validates /agents.txt and /agents.json against §3–§11, §5 schema, §4.5 serving headers, and cross-file consistency. Shareable result URL, JSON and Markdown representations available via content negotiation."
  canonicalUrl="https://agents-txt.com/audit"
>
  <!-- Nav -->
  <header class="sticky top-0 z-50 bg-white border-b border-[#e5e5e5]">
    <div class="max-w-[1280px] mx-auto px-6 sm:px-10 h-14 flex items-center justify-between gap-4">
      <div class="flex items-center gap-3 min-w-0">
        <a href="/" class="flex items-center no-underline shrink-0" aria-label="agents.txt"><img src="/assets/mark-2.svg" alt="agents.txt" width="26" height="26" class="h-[26px] w-[26px]" /></a>
        <span class="hidden sm:inline text-[#ccc] select-none">/</span>
        <span class="hidden sm:inline text-sm text-[#555] whitespace-nowrap">Audit</span>
      </div>
      <NavRight current="audit" />
    </div>
  </header>

  <!-- Page body -->
  <div class="max-w-[1280px] mx-auto px-6 sm:px-10 pt-12 pb-24">
    <main class="max-w-3xl mx-auto">

      <!-- Cover -->
      <div class="mb-10 pb-8 border-b border-[#e5e5e5]">
        <h1 class="text-2xl font-bold tracking-tight text-[#111] mb-1">
          Audit a site against the agents.txt spec
        </h1>
        <p class="text-sm text-[#777] font-mono mb-6">/agents.txt · /agents.json · §3–§11 directives · §5 schema · §4.5 serving · cross-file consistency</p>
        <dl class="grid grid-cols-[auto_1fr] gap-x-6 gap-y-2 text-sm">
          <dt class="text-[#999] font-medium">Standard</dt>
          <dd class="text-[#111]">
            <a href="/spec" class="font-mono underline underline-offset-2 decoration-[#bbb] hover:decoration-[#111] transition-all">
              agents.txt v{SPEC_VERSION}
            </a>
          </dd>
          <dt class="text-[#999] font-medium">Discovery</dt>
          <dd class="font-mono text-[#111]">/audit?url=&lt;target&gt; · /mcp <span class="text-[#999]">(audit_site tool)</span></dd>
          <dt class="text-[#999] font-medium">Transport</dt>
          <dd class="text-[#111]">HTTPS · content-negotiated <span class="font-mono">application/json · text/markdown · text/html</span></dd>
          <dt class="text-[#999] font-medium">Status</dt>
          <dd class="text-[#111]">
            <span class="inline-flex items-center border border-[#111] text-[10px] font-semibold tracking-[0.08em] uppercase px-1.5 py-0.5 leading-none mr-2">Live</span>
            Auditing any site you paste, in real time.
          </dd>
        </dl>
      </div>

      <!-- Introduction -->
      <div class="prose max-w-none mb-10">
        <p>
          Paste a site origin or full URL. The audit fetches <code>/agents.txt</code>, <code>/agents.json</code>, and <code>/robots.txt</code> from that origin, validates each against the agents.txt specification, cross-checks the two discovery files for consistency, and returns a structured report. The same URL serves three representations via content negotiation: HTML for browsers, <code>application/json</code> for scripts, <code>text/markdown</code> for LLM agents.
        </p>
        <p>
          Result URLs are shareable. Cache TTL is one hour per target.
        </p>
      </div>

      <!-- Form -->
      <form id="audit-form" class="border border-[#e5e5e5] mb-8">
        <div class="px-5 py-4 border-b border-[#e5e5e5]">
          <p class="text-sm font-semibold text-[#111]">Target site</p>
          <p class="text-xs text-[#999] mt-0.5">Origin or any URL on the site. The audit always runs against the origin.</p>
        </div>
        <div class="px-5 py-4 flex flex-col sm:flex-row gap-3">
          <input
            id="audit-input"
            name="url"
            type="text"
            placeholder="https://example.com"
            autocomplete="off"
            spellcheck="false"
            class="flex-1 border border-[#e5e5e5] bg-white px-3 py-2 text-sm font-mono focus:outline-none focus:border-[#111] transition-colors"
          />
          <button
            type="submit"
            class="cursor-pointer flex items-center justify-center gap-2 border border-[#111] bg-[#111] text-white text-xs font-semibold tracking-[0.06em] uppercase px-5 py-2 hover:bg-white hover:text-[#111] transition-colors"
          >
            Audit
          </button>
        </div>
      </form>

      <!-- Result container. Populated on page load from #audit-data (when the
           worker injected an envelope) or after the form submit. -->
      <div id="audit-result" class="hidden"></div>

      <!-- Empty state visible when no audit has been run yet. -->
      <div id="audit-empty" class="border border-dashed border-[#e5e5e5] px-5 py-12 text-center">
        <p class="text-sm text-[#777]">Paste a URL above to run an audit.</p>
        <p class="text-xs text-[#999] mt-2 font-mono">curl -H 'Accept: application/json' https://agents-txt.com/audit?url=&lt;target&gt;</p>
      </div>

      <!-- Other representations -->
      <div class="prose max-w-none mt-16">
        <h2>Programmatic access</h2>
        <p>
          The same URL serves all three formats. Pick by <code>Accept</code> header:
        </p>
        <pre><code>{`# JSON
curl -H 'Accept: application/json' \\
  'https://agents-txt.com/audit?url=https://example.com'

# Markdown (for LLMs and copy-paste into chat threads)
curl -H 'Accept: text/markdown' \\
  'https://agents-txt.com/audit?url=https://example.com'

# HTML (default; what the browser sees)
curl 'https://agents-txt.com/audit?url=https://example.com'`}</code></pre>
        <p>
          MCP-speaking agents can also call the underlying <code>audit_site</code> tool over <code>/mcp</code> directly. The tool's response shape is identical to the JSON returned here.
        </p>
      </div>

    </main>
  </div>

  <!-- Worker-injected audit envelope. Defaults to an empty object so the
       page renders the empty state when nobody has been audited yet.
       `is:inline` is explicit so Astro does not try to bundle the JSON
       contents as a module; this tag is a data island, not executable code. -->
  <script id="audit-data" type="application/json" is:inline>{}</script>

  <!-- Footer -->
  <footer class="border-t border-[#e5e5e5] mt-4">
    <div class="max-w-[1280px] mx-auto px-6 sm:px-10 py-8 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
      <div class="text-xs text-[#999]">
        <img src="/assets/wordmark.svg" alt="agents.txt" class="inline-block h-[16px] w-auto align-middle" />
        {' '}
        <a href="/spec" class="underline underline-offset-2 decoration-[#ccc] hover:decoration-[#999] transition-all">Spec</a>
        {' '}·{' '}
        <a href="/registry" class="underline underline-offset-2 decoration-[#ccc] hover:decoration-[#999] transition-all">Registry</a>
        {' '}·{' '}
        <a href="/demo" class="underline underline-offset-2 decoration-[#ccc] hover:decoration-[#999] transition-all">Demos</a>
      </div>
      <p class="text-xs text-[#bbb]">CC0 (spec) · Apache 2.0 (code).</p>
    </div>
  </footer>
</BaseLayout>

<style>
  /* Issue rows are native <details> matched to the landing page's route-group
     pattern: hide the default disclosure marker, rotate a custom chevron when
     the issue is open, clamp the summary text to 3 lines while collapsed and
     unclamp it while open. */
  details.audit-issue > summary { list-style: none; }
  details.audit-issue > summary::-webkit-details-marker { display: none; }
  details.audit-issue > summary .chevron { transition: transform 200ms ease-out; }
  details.audit-issue[open] > summary .chevron { transform: rotate(90deg); }
  details.audit-issue > summary .audit-detail {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  details.audit-issue[open] > summary .audit-detail {
    display: block;
    -webkit-line-clamp: unset;
    overflow: visible;
  }
  /* Long URLs in cross-check messages wrap rather than horizontal-scroll. */
  .audit-detail { word-break: break-word; overflow-wrap: anywhere; }
</style>

<script>
  interface AuditEnvelopeOk   { ok: true;  target: string; cached: boolean; fetchedAt: string; report: Record<string, unknown> }
  interface AuditEnvelopeErr  { ok: false; target: string; error: string; message: string }
  type AuditEnvelope = AuditEnvelopeOk | AuditEnvelopeErr;

  const form   = document.getElementById('audit-form') as HTMLFormElement | null;
  const input  = document.getElementById('audit-input') as HTMLInputElement | null;
  const result = document.getElementById('audit-result');
  const empty  = document.getElementById('audit-empty');
  const dataEl = document.getElementById('audit-data');

  // Pre-fill the input from ?url= so the form value reflects the URL bar.
  const params = new URLSearchParams(window.location.search);
  const initialTarget = params.get('url');
  if (initialTarget && input) input.value = initialTarget;

  // Submit → navigate to /audit?url=… so the result URL is shareable.
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    const value = (input?.value ?? '').trim();
    if (!value) return;
    window.location.href = `/audit?url=${encodeURIComponent(value)}`;
  });

  function renderEnvelope(env: AuditEnvelope) {
    if (!result || !empty) return;
    empty.classList.add('hidden');
    result.classList.remove('hidden');
    result.innerHTML = '';

    if (!env.ok) {
      result.appendChild(card(
        `Audit failed`,
        `<p class="text-sm text-[#c00] mb-1"><span class="font-mono text-[11px]">${escape(env.error)}</span></p>
         <p class="text-sm text-[#555]">${escape(env.message)}</p>`,
      ));
      return;
    }

    const report = env.report as Record<string, unknown>;
    const score = computeScore(report);
    result.appendChild(renderScoreCard(env, score));

    // Animate the score on insertion: the ring and the filled bar segments
    // render empty, then sweep to their target values on the next frame.
    requestAnimationFrame(() => {
      result.querySelectorAll<HTMLElement>('[data-seg-fill]').forEach((seg) => {
        seg.style.transform = 'scaleX(1)';
      });
      result.querySelectorAll<SVGCircleElement>('[data-ring]').forEach((r) => {
        r.style.strokeDashoffset = r.dataset.target ?? '0';
      });
    });

    // Per-file sections. Wrapped in try/catch so a render bug on one block
    // doesn't kill the rest of the report. Each block also synthesises a
    // not-found placeholder if missing entirely from the upstream report.
    const safeRender = (label: string, key: string) => {
      try {
        const block = report[key] ?? { found: false, status: 0, validation: { valid: false, errors: [], warnings: [] } };
        renderFileSection(result, label, block);
      } catch (err) {
        console.error('renderFileSection failed', label, err);
        result.appendChild(card(label, `<p class="text-xs text-[#c00]">Render error: ${escape(String(err))}</p>`, true));
      }
    };
    safeRender('/agents.txt',  'agentsTxt');
    safeRender('/agents.json', 'agentsJson');
    safeRender('/robots.txt',  'robotsTxt');

    // Capabilities: per-block detail card. Doesn't contribute to the score
    // (per the "informational" rule on the score card), but surfaces what
    // the site actually declared in each block so the audit doubles as a
    // discovery summary.
    try { renderCapabilitiesSection(result, report); }
    catch (err) { console.error('renderCapabilitiesSection failed', err); }

    const consistency = report.consistency as { valid?: boolean; issues?: string[]; note?: string } | undefined;
    if (consistency) {
      const rows: string[] = [];
      if (consistency.valid && !(consistency.issues && consistency.issues.length)) {
        rows.push(`<p class="text-sm text-[#555]">${consistency.note ? escape(consistency.note) : 'Consistent.'}</p>`);
      } else if (consistency.issues) {
        rows.push(`<ul class="space-y-2 mt-2">${consistency.issues.map(i => renderIssue('error', i)).join('')}</ul>`);
      }
      result.appendChild(card('Cross-file consistency', rows.join('')));
    }
  }

  // ── Agent-readiness score ───────────────────────────────────────────────
  // The audit report is per-file pass/fail. The score rolls it into a single
  // percentage across four spec-compliance categories, plus a non-scored
  // "Capabilities" tally of how many protocol blocks the site declares.
  interface CatScore  { label: string; got: number; max: number; optional?: boolean }
  interface Protocol  { label: string; present: boolean }
  interface Readiness {
    pct: number; grade: string; level: string; color: string;
    categories: CatScore[]; protocols: Protocol[];
    errorCount: number; warningCount: number;
  }

  function computeScore(report: Record<string, unknown>): Readiness {
    const txt    = (report.agentsTxt   as Record<string, unknown>) ?? {};
    const json   = (report.agentsJson  as Record<string, unknown>) ?? {};
    const robots = (report.robotsTxt   as Record<string, unknown>) ?? {};
    const consistency = (report.consistency as { valid?: boolean }) ?? {};
    const summary     = (report.summary     as { errorCount?: number; warningCount?: number }) ?? {};

    const txtVal  = (txt.validation  as { valid?: boolean; errors?: string[] }) ?? {};
    const jsonVal = (json.validation as { valid?: boolean; errors?: string[] }) ?? {};
    const txtErrors  = txtVal.errors  ?? [];
    const jsonErrors = jsonVal.errors ?? [];

    const txtFound  = txt.found  === true;
    const jsonFound = json.found === true;
    const jsonParsed = json.parsed as Record<string, unknown> | null | undefined;

    // §4.5 / §5 sub-checks are derived from the error strings the MCP audit
    // tags with section numbers — no error from that section means it passed.
    const servesOk  = (errs: string[]) => !errs.some((e) => e.includes('§4.5'));
    const schemaOk  = (errs: string[]) => !errs.some((e) => e.startsWith('§5'));
    const count = (b: boolean[]) => b.filter(Boolean).length;

    const discovery = [
      txtFound,
      jsonFound,
      robots.found === true && (robots as { allowsAgentsTxt?: boolean }).allowsAgentsTxt === true,
    ];
    const validity = [
      txtVal.valid === true,
      jsonVal.valid === true,
      consistency.valid === true,
    ];
    const serving = [
      txtFound  && servesOk(txtErrors),
      jsonFound && servesOk(jsonErrors),
    ];
    const schema = [
      jsonFound && !json.parseError && schemaOk(jsonErrors),
      !!(jsonParsed && typeof jsonParsed === 'object' && '$schema' in jsonParsed),
    ];

    const categories: CatScore[] = [
      { label: 'Discovery',    got: count(discovery), max: 3 },
      { label: 'Validity',     got: count(validity),  max: 3 },
      { label: 'Serving',      got: count(serving),   max: 2 },
      { label: 'Schema',       got: count(schema),    max: 2 },
    ];

    // Protocol detection from whichever discovery file parsed cleanly.
    const p = (txt.parsed as Record<string, unknown> | undefined)
            ?? jsonParsed ?? {};
    const present = (key: string): boolean => {
      const v = (p as Record<string, unknown>)[key];
      if (Array.isArray(v)) return v.length > 0;
      if (v && typeof v === 'object') return Object.keys(v).length > 0;
      return false;
    };
    // Block-level pills (one per capability area) plus per-identifier pills
    // for the two blocks that carry a `protocols[]` array (Payments, Auth).
    // Per-identifier pills surface specific declarations like `x402`, `mpp`,
    // `agent-auth`, `auth-md` that the block-level pill alone hides.
    const identifiers = (key: string): string[] => {
      const block = (p as Record<string, unknown>)[key];
      if (!block || typeof block !== 'object') return [];
      const arr = (block as Record<string, unknown>).protocols;
      if (Array.isArray(arr)) return arr.filter((v): v is string => typeof v === 'string');
      return [];
    };
    const protocols: Protocol[] = [
      { label: 'MCP',      present: present('mcp')           },
      { label: 'Skills',   present: present('skills')        },
      { label: 'A2A',      present: present('a2a')           },
      { label: 'UCP',      present: present('ucp')           },
      { label: 'Payments', present: present('payments')      },
      ...identifiers('payments').map((id) => ({ label: id, present: true })),
      { label: 'Auth',     present: present('authorization') },
      ...identifiers('authorization').map((id) => ({ label: id, present: true })),
    ];
    categories.push({
      label: 'Capabilities',
      got: protocols.filter((x) => x.present).length,
      max: protocols.length,
      optional: true,
    });

    const scored = categories.filter((c) => !c.optional);
    const got = scored.reduce((s, c) => s + c.got, 0);
    const max = scored.reduce((s, c) => s + c.max, 0);
    const pct = max ? Math.round((got / max) * 100) : 0;

    const grade = pct >= 90 ? 'A' : pct >= 75 ? 'B' : pct >= 60 ? 'C' : pct >= 40 ? 'D' : 'F';
    const level = pct >= 90 ? 'Agent-Native'
                : pct >= 70 ? 'Agent-Ready'
                : pct >= 45 ? 'Agent-Aware'
                : pct >  0  ? 'Minimal'
                :             'Not Ready';
    const color = pct >= 75 ? '#16a34a' : pct >= 45 ? '#d97706' : '#dc2626';

    return {
      pct, grade, level, color, categories, protocols,
      errorCount: summary.errorCount ?? 0,
      warningCount: summary.warningCount ?? 0,
    };
  }

  // Category colour: green when complete, amber when partial, red when zero.
  // The optional Capabilities row is neutral — it counts protocol coverage,
  // which is informational and never penalised.
  function categoryColor(c: CatScore): string {
    if (c.optional) return c.got > 0 ? '#111' : '#bbb';
    return c.got === c.max ? '#16a34a' : c.got > 0 ? '#d97706' : '#dc2626';
  }

  // A category's segmented bar: `max` equal cells, the first `got` filled.
  // Filled cells render collapsed (scaleX 0) and carry `data-seg-fill` so the
  // caller can sweep them in left-to-right; `baseIndex` staggers the sweep
  // across the whole card so rows fill in sequence rather than all at once.
  function segBar(c: CatScore, color: string, baseIndex: number): string {
    let cells = '';
    for (let i = 0; i < c.max; i++) {
      const filled = i < c.got;
      if (filled) {
        const delay = (baseIndex + i) * 45;
        cells += `<span class="flex-1 h-2.5" data-seg-fill style="background:${color};transform:scaleX(0);transform-origin:left;transition:transform .45s cubic-bezier(.2,.7,.2,1) ${delay}ms"></span>`;
      } else {
        cells += `<span class="flex-1 h-2.5" style="background:#ededed"></span>`;
      }
    }
    return cells;
  }

  // Semi-circle gauge. Top-half arc from (10,60) to (110,60) via radius 50,
  // animated via stroke-dashoffset the same way the segment bars are. The
  // percentage sits inside the arc with a tiny "/100" hint underneath; the
  // arc starts empty (dashoffset = arc length) and sweeps to `data-target`
  // on the next frame.
  function ring(pct: number, color: string): string {
    const r = 50;
    const arcLen = Math.PI * r;                          // semi-circle = πr
    const clamped = Math.max(0, Math.min(100, pct));
    const target = (arcLen * (1 - clamped / 100)).toFixed(2);
    const arcPath = `M 10 60 A ${r} ${r} 0 0 1 110 60`;  // top-half arc
    return `
      <svg viewBox="0 0 120 70" class="w-[120px] h-[70px] shrink-0" role="img" aria-label="${pct} of 100 agent readiness">
        <path d="${arcPath}" fill="none" stroke="#ededed" stroke-width="8" stroke-linecap="round" />
        <path d="${arcPath}" fill="none" stroke="${color}" stroke-width="8" stroke-linecap="round"
              data-ring data-target="${target}"
              stroke-dasharray="${arcLen.toFixed(2)}" stroke-dashoffset="${arcLen.toFixed(2)}"
              style="transition:stroke-dashoffset .9s cubic-bezier(.2,.7,.2,1)" />
        <text x="60" y="52" text-anchor="middle" font-size="22" font-weight="700"
              fill="${color}" font-family="ui-sans-serif,system-ui,sans-serif">${pct}</text>
        <text x="60" y="65" text-anchor="middle" font-size="8" font-weight="500"
              fill="#999" font-family="ui-sans-serif,system-ui,sans-serif" letter-spacing="0.5">/ 100</text>
      </svg>`;
  }

  function renderScoreCard(env: AuditEnvelopeOk, score: Readiness): HTMLElement {
    const wrap = document.createElement('div');
    wrap.className = 'border border-[#e5e5e5] mb-4';

    const cachedTag = env.cached
      ? ` · <span class="font-mono text-[10px]">cached ${escape(env.fetchedAt.slice(0, 19))}Z · <a href="/audit?url=${encodeURIComponent(env.target)}&nocache=1" class="underline underline-offset-2 decoration-[#ccc] hover:decoration-[#111] hover:text-[#111] transition-colors">re-run</a></span>`
      : '';

    let segIndex = 0;
    const rows = score.categories.map((c) => {
      const color = categoryColor(c);
      const cells = segBar(c, color, segIndex);
      segIndex += c.max;
      return `
        <div class="flex items-center gap-3 py-[5px]">
          <span class="w-24 sm:w-28 shrink-0 text-[11px] text-[#555]">${escape(c.label)}</span>
          <span class="flex-1 flex gap-[2px] overflow-hidden">${cells}</span>
          <span class="w-9 shrink-0 text-right font-mono text-[11px]" style="color:${color}">${c.got}/${c.max}</span>
        </div>`;
    }).join('');

    const pills = score.protocols.map((p) => `
      <span class="inline-flex items-center gap-1.5 border px-2.5 py-1 text-[11px] font-mono ${p.present ? 'border-[#111] text-[#111]' : 'border-[#e5e5e5] text-[#ccc]'}">
        <span class="${p.present ? 'text-[#16a34a]' : ''}">${p.present ? '✓' : '·'}</span>${escape(p.label)}
      </span>`).join('');

    wrap.innerHTML = `
      <div class="px-5 py-3 border-b border-[#e5e5e5] bg-[#fafafa]">
        <p class="text-[11px] font-semibold uppercase tracking-[0.08em] text-[#999]">Agent readiness</p>
      </div>
      <div class="flex items-center justify-between gap-4 px-5 py-4 border-b border-[#e5e5e5]">
        <div class="min-w-0">
          <p class="font-mono text-xs text-[#555] break-all">${escape(env.target)}</p>
          <p class="mt-1.5">
            <span class="inline-flex items-center border border-[#111] text-[10px] font-semibold tracking-[0.08em] uppercase px-1.5 py-0.5 leading-none">Grade ${escape(score.grade)}</span>
          </p>
          <p class="text-sm font-medium text-[#111] mt-1.5">${escape(score.level)}</p>
          <p class="text-xs text-[#999] mt-1">${score.errorCount} error${score.errorCount === 1 ? '' : 's'} · ${score.warningCount} warning${score.warningCount === 1 ? '' : 's'}${cachedTag}</p>
        </div>
        ${ring(score.pct, score.color)}
      </div>
      <div class="px-5 py-4 border-b border-[#e5e5e5]">
        ${rows}
        <p class="text-[10px] text-[#bbb] mt-3 pt-3 border-t border-[#f0f0f0]">Discovery, Validity, Serving and Schema set the score. Capabilities is informational — protocol coverage is never penalised.</p>
      </div>
      <div class="px-5 py-5">
        <p class="text-[10px] font-semibold uppercase tracking-[0.08em] text-[#999] mb-3">Protocols declared</p>
        <div class="flex flex-wrap gap-2">${pills}</div>
      </div>`;
    return wrap;
  }

  function renderFileSection(parent: HTMLElement, label: string, block: unknown) {
    if (!block || typeof block !== 'object') return;
    const b = block as Record<string, unknown>;
    const found = b.found === true;
    const status = typeof b.status === 'number' ? b.status : null;
    const validation = (b.validation as { valid?: boolean; errors?: string[]; warnings?: string[] } | undefined) ?? {};
    const errors   = validation.errors ?? [];
    const warnings = validation.warnings ?? [];

    // Header pills: served / not found, HTTP status, and a validation badge
    // when the file was actually fetched. The validation badge replaces the
    // bare HTTP code with what the validator concluded — "valid", "N errors",
    // or "N warnings" — so the row is informative even on a clean 200.
    const pill = (text: string, opts: { tone: 'ok' | 'warn' | 'err' | 'mute' }): string => {
      const palette = {
        ok:   { border: '#16a34a', text: '#16a34a', bg: '#f0fdf4' },
        warn: { border: '#a16207', text: '#a16207', bg: '#fefce8' },
        err:  { border: '#c00',    text: '#c00',    bg: '#fef2f2' },
        mute: { border: '#e5e5e5', text: '#555',    bg: '#fafafa' },
      }[opts.tone];
      return `<span class="inline-flex items-center border px-2 py-0.5 text-[10px] font-mono"
              style="border-color:${palette.border};color:${palette.text};background:${palette.bg}">${escape(text)}</span>`;
    };
    const pills: string[] = [];
    if (found) {
      pills.push(pill('served', { tone: 'ok' }));
      if (status) pills.push(pill(`HTTP ${status}`, { tone: 'mute' }));
      if (validation.valid === true && errors.length === 0 && warnings.length === 0) {
        pills.push(pill('valid', { tone: 'ok' }));
      } else if (errors.length > 0) {
        pills.push(pill(`${errors.length} error${errors.length === 1 ? '' : 's'}`, { tone: 'err' }));
        if (warnings.length > 0) pills.push(pill(`${warnings.length} warning${warnings.length === 1 ? '' : 's'}`, { tone: 'warn' }));
      } else if (warnings.length > 0) {
        pills.push(pill(`valid · ${warnings.length} warning${warnings.length === 1 ? '' : 's'}`, { tone: 'warn' }));
      }
    } else {
      pills.push(pill('not found', { tone: 'err' }));
      if (status) pills.push(pill(`HTTP ${status}`, { tone: 'err' }));
    }

    let body = `<div class="mb-3 flex flex-wrap gap-1.5">${pills.join('')}</div>`;
    if (!found) {
      // Sourceless miss. Two things end up in the issue list: the real
      // §-tagged validation errors / warnings emitted by the MCP audit
      // (when present), plus a synthetic placeholder when MCP returned no
      // findings of its own. Either way the path is informative — the audit
      // can't validate what isn't there, but it points at the section that
      // defines the path so the operator has a fix to act on.
      const items: Array<{ level: 'error' | 'warning'; text: string }> = [
        ...errors.map((e) => ({ level: 'error' as const, text: e })),
        ...warnings.map((w) => ({ level: 'warning' as const, text: w })),
      ];
      if (items.length === 0) {
        const synthetic = label === '/agents.txt'
          ? '§4.1: /agents.txt MUST be served at the site origin (HTTP 200, text/plain)'
          : label === '/agents.json'
            ? '§4.1: /agents.json MUST be served at the site origin (HTTP 200, application/json)'
            : label === '/robots.txt'
              ? '§4.3: /robots.txt should be served at the site origin with an Allow: /agents.txt rule'
              : `${label}: not served`;
        items.push({ level: 'error', text: synthetic });
      }
      body += `<ul class="space-y-2">${items.map((i) => renderIssue(i.level, i.text)).join('')}</ul>`;
    } else if (errors.length === 0 && warnings.length === 0) {
      // Positive confirmation. Each file has a specific thing the audit just
      // confirmed; saying so beats a generic "No findings."
      const okMessage = label === '/agents.txt'
        ? 'Valid against §3 directives, §4.5 serving headers, and §14 secret hygiene.'
        : label === '/agents.json'
          ? 'Valid against the §5 schema and §14 secret hygiene. Schema reference present.'
          : label === '/robots.txt'
            ? 'Allows /agents.txt per §4.3.'
            : 'All checks passed.';
      body += `
        <div class="border border-[#e5e5e5] bg-[#fafafa] px-3 py-2.5">
          <p class="text-[10px] font-semibold uppercase tracking-[0.08em] text-[#999] mb-0.5">
            <span class="text-[#16a34a] mr-1">✓</span>All checks passed
          </p>
          <p class="text-xs text-[#555] leading-relaxed">${escape(okMessage)}</p>
        </div>`;
    } else {
      body += `<ul class="space-y-2">`;
      errors.forEach(e => { body += renderIssue('error', e); });
      warnings.forEach(w => { body += renderIssue('warning', w); });
      body += `</ul>`;
    }
    parent.appendChild(card(label, body, true));
  }

  // ── Capabilities section ────────────────────────────────────────────────
  // One card with a dropdown per declared block. Pulls from the parsed
  // agents.json first (richer field set) and falls back to the parsed
  // agents.txt when only the plain-text file was served. Skipped entirely
  // when neither file parsed.
  function renderCapabilitiesSection(parent: HTMLElement, report: Record<string, unknown>) {
    const txt  = (report.agentsTxt  as Record<string, unknown>) ?? {};
    const json = (report.agentsJson as Record<string, unknown>) ?? {};
    const p = (json.parsed as Record<string, unknown> | undefined)
            ?? (txt.parsed as Record<string, unknown> | undefined)
            ?? null;
    if (!p) return;

    type Row = { label: string; href?: string; meta?: string };
    interface Block { key: string; title: string; section: string; rows: Row[]; summary: string }
    const blocks: Block[] = [];

    // MCP — endpoints with optional descriptions
    const mcp = asArray((p as Record<string, unknown>).mcp);
    if (mcp.length) {
      blocks.push({
        key: 'mcp', title: 'MCP', section: '§6',
        summary: `${mcp.length} endpoint${mcp.length === 1 ? '' : 's'}`,
        rows: mcp.map((m) => ({
          label: stringField(m, 'url') ?? '(no url)',
          href:  stringField(m, 'url'),
          meta:  stringField(m, 'description'),
        })),
      });
    }
    // Skills — URLs (+ name/type/digest when present, from agentskills v0.2.0)
    const skills = asArray((p as Record<string, unknown>).skills);
    if (skills.length) {
      blocks.push({
        key: 'skills', title: 'Skills', section: '§7',
        summary: `${skills.length} skill${skills.length === 1 ? '' : 's'}`,
        rows: skills.map((s) => {
          const url = stringField(s, 'url') ?? '(no url)';
          const name = stringField(s, 'name');
          const digest = stringField(s, 'digest');
          const meta = [stringField(s, 'description'), digest && `digest: ${digest}`]
            .filter(Boolean).join(' · ');
          return { label: name ?? url, href: stringField(s, 'url'), meta };
        }),
      });
    }
    // A2A AgentCards
    const a2a = asArray((p as Record<string, unknown>).a2a);
    if (a2a.length) {
      blocks.push({
        key: 'a2a', title: 'A2A', section: '§9',
        summary: `${a2a.length} card${a2a.length === 1 ? '' : 's'}`,
        rows: a2a.map((c) => ({
          label: stringField(c, 'url') ?? '(no url)',
          href:  stringField(c, 'url'),
          meta:  stringField(c, 'description'),
        })),
      });
    }
    // UCP profiles
    const ucp = asArray((p as Record<string, unknown>).ucp);
    if (ucp.length) {
      blocks.push({
        key: 'ucp', title: 'UCP', section: '§10',
        summary: `${ucp.length} profile${ucp.length === 1 ? '' : 's'}`,
        rows: ucp.map((u) => ({
          label: stringField(u, 'url') ?? '(no url)',
          href:  stringField(u, 'url'),
          meta:  stringField(u, 'description'),
        })),
      });
    }
    // WebMCP pages
    const webmcp = asArray((p as Record<string, unknown>).webmcp);
    if (webmcp.length) {
      blocks.push({
        key: 'webmcp', title: 'WebMCP', section: '§6.6',
        summary: `${webmcp.length} page${webmcp.length === 1 ? '' : 's'}`,
        rows: webmcp.map((w) => ({
          label: stringField(w, 'url') ?? '(no url)',
          href:  stringField(w, 'url'),
          meta:  stringField(w, 'description'),
        })),
      });
    }
    // Payments — per-protocol detail (pricing, chains, methods)
    const payments = (p as Record<string, unknown>).payments as Record<string, unknown> | undefined;
    if (payments) {
      const rows: Row[] = [];
      const required = payments.required === true;
      if (required) rows.push({ label: 'Payments: required', meta: 'Every interaction requires payment.' });
      const pricing = payments.pricing as Record<string, unknown> | undefined;
      if (pricing && (pricing.amount || pricing.token || pricing.currency)) {
        rows.push({
          label: 'Pricing',
          meta: [
            pricing.amount ? String(pricing.amount) : null,
            (pricing.token || pricing.currency) ? String(pricing.token ?? pricing.currency) : null,
          ].filter(Boolean).join(' '),
        });
      }
      for (const id of Object.keys(payments)) {
        if (id === 'required' || id === 'pricing') continue;
        const block = payments[id] as Record<string, unknown> | undefined;
        if (!block || typeof block !== 'object') continue;
        const parts: string[] = [];
        if (Array.isArray(block.chains))        parts.push(`chains: ${(block.chains as unknown[]).join(', ')}`);
        if (Array.isArray(block.methods))       parts.push(`methods: ${(block.methods as unknown[]).join(', ')}`);
        if (Array.isArray(block.presentations)) parts.push(`presentations: ${(block.presentations as unknown[]).join(', ')}`);
        if (typeof block.description === 'string') parts.push(block.description);
        rows.push({ label: id, meta: parts.join(' · ') || undefined });
      }
      if (rows.length) {
        const ids = Object.keys(payments).filter((k) => k !== 'required' && k !== 'pricing');
        blocks.push({
          key: 'payments', title: 'Payments', section: '§8',
          summary: ids.length ? ids.join(', ') : 'declared',
          rows,
        });
      }
    }
    // Authorization — protocols list, discovery pointer, identity flag
    const auth = (p as Record<string, unknown>).authorization as Record<string, unknown> | undefined;
    if (auth) {
      const rows: Row[] = [];
      const protocols = Array.isArray(auth.protocols) ? auth.protocols as string[] : [];
      protocols.forEach((id) => rows.push({ label: id }));
      if (typeof auth.discovery === 'string') {
        rows.push({ label: 'Discovery', meta: auth.discovery });
      }
      if (auth.identity === 'required' || auth.identityRequired === true) {
        rows.push({ label: 'Identity: required', meta: 'Authentication required before any interaction (§11.4).' });
      }
      if (rows.length) {
        blocks.push({
          key: 'auth', title: 'Authorization', section: '§11',
          summary: protocols.length ? protocols.join(', ') : 'declared',
          rows,
        });
      }
    }

    if (!blocks.length) return;

    const body = blocks.map((b) => `
      <details class="audit-issue border border-[#e5e5e5] bg-white mb-2 last:mb-0">
        <summary class="grid grid-cols-[1fr_auto] gap-x-3 px-3 py-2.5 cursor-pointer hover:bg-[#fafafa] transition-colors items-center">
          <span class="flex items-center gap-2 min-w-0">
            <span class="chevron inline-block w-3 text-[#999] text-[10px] shrink-0">▸</span>
            <span class="text-xs font-semibold text-[#111]">${escape(b.title)}</span>
            <span class="font-mono text-[10px] text-[#999]">${escape(b.section)}</span>
          </span>
          <span class="text-[10px] font-mono text-[#777] truncate">${escape(b.summary)}</span>
        </summary>
        <ul class="ml-7 mr-3 pb-3 space-y-1.5 list-none p-0">
          ${b.rows.map((r) => `
            <li class="border-l-2 border-[#e5e5e5] pl-3 py-1">
              <p class="text-xs text-[#111] break-all">
                ${r.href
                  ? `<a href="${escape(r.href)}" target="_blank" rel="noopener noreferrer" class="font-mono underline underline-offset-2 decoration-[#bbb] hover:decoration-[#111] transition-colors">${escape(r.label)}</a>`
                  : `<span class="font-mono">${escape(r.label)}</span>`}
              </p>
              ${r.meta ? `<p class="text-[11px] text-[#777] leading-relaxed mt-0.5">${escape(r.meta)}</p>` : ''}
            </li>
          `).join('')}
        </ul>
      </details>
    `).join('');

    const note = `<p class="text-[10px] text-[#bbb] mt-3 pt-3 border-t border-[#f0f0f0]">Informational. Capability coverage is never penalised in the score; this section reflects what the site declared, not what it must declare.</p>`;
    parent.appendChild(card('Capabilities declared', body + note));
  }

  function asArray(v: unknown): Record<string, unknown>[] {
    if (!Array.isArray(v)) return [];
    return v.filter((x): x is Record<string, unknown> => !!x && typeof x === 'object');
  }
  function stringField(o: unknown, k: string): string | undefined {
    if (!o || typeof o !== 'object') return undefined;
    const v = (o as Record<string, unknown>)[k];
    return typeof v === 'string' && v ? v : undefined;
  }

  // ── Fix-hint lookup ──────────────────────────────────────────────────────
  // The MCP audit tool prefixes every finding with the spec section it cites
  // (e.g. "§4.5: missing Access-Control-Allow-Origin"). The lookup below maps
  // section-keys (and a handful of high-value phrase keys) to a one-line fix
  // and the canonical spec anchor. Falls back to a generic "see this section"
  // hint when the key is unknown, so coverage is always non-empty.
  interface FixHint { fix: string; href: string; anchor: string }
  const SECTION_TITLES: Record<string, string> = {
    '3':    '§3 File Format',
    '3.1':  '§3.1 Directives',
    '3.2':  '§3.2 Parsing Rules',
    '4.1':  '§4.1 Well-Known Paths',
    '4.2':  '§4.2 # JSON: comment',
    '4.3':  '§4.3 robots.txt Discovery',
    '4.5':  '§4.5 Serving Requirements',
    '5':    '§5 agents.json Schema',
    '5.2':  '§5.2 Schema',
    '5.3':  '§5.3 Field Notes',
    '5.4':  '§5.4 Secret Hygiene',
    '6':    '§6 MCP',
    '6.6':  '§6.6 WebMCP',
    '7':    '§7 Skills',
    '8':    '§8 Payments',
    '9':    '§9 A2A',
    '10':   '§10 UCP',
    '11':   '§11 Authorization',
    '12':   '§12 Existing Standards',
    '14':   '§14 Security',
  };
  const PHRASE_FIXES: Array<{ match: RegExp; fix: string }> = [
    { match: /allow.*agents\.txt|robots.*does not allow/i,
      fix: 'Add `Allow: /agents.txt` to the default wildcard block in robots.txt.' },
    { match: /Access-Control-Allow-Origin/i,
      fix: 'Add `Access-Control-Allow-Origin: *` to the response headers for this path.' },
    { match: /Content-Type.*charset|missing charset/i,
      fix: 'Add `; charset=utf-8` to the Content-Type. Example: `text/plain; charset=utf-8`.' },
    { match: /Content-Type/i,
      fix: 'Set Content-Type to `text/plain; charset=utf-8` for /agents.txt or `application/json` for /agents.json.' },
    { match: /Cache-Control/i,
      fix: 'Set `Cache-Control: public, max-age=3600` on the response.' },
    { match: /file MUST be served at the canonical path/i,
      fix: 'Serve the file at its canonical well-known path. The audit fetches only the path defined by §4.1.' },
    { match: /\$schema/i,
      fix: 'Add `"$schema": "https://agents-txt.com/schema/agents-json/v1.0.json"` at the top of agents.json so editors and validators can resolve the canonical schema.' },
    { match: /unknown directive|unrecognized directive/i,
      fix: 'Either remove the directive or prefix it with `x-` to signal an experimental identifier (§3.1).' },
    { match: /HTTPS/i,
      fix: 'Replace the http:// URL with an https:// URL. agents.txt §3.1 requires HTTPS for every URL-valued directive.' },
    { match: /secret|token|api[_-]?key|wallet/i,
      fix: 'Remove the credential from the discovery file. Treasury addresses live in 402 responses; API keys and JWKs are server-side only (§5.4).' },
    { match: /Identity: required/i,
      fix: 'Emit `Identity: required` inside the Authorization block when site-level auth applies to every interaction (§11.4).' },
    { match: /Payments: required/i,
      fix: 'Emit `Payments: required` inside the Payments block when every interaction requires payment (§8.4).' },
    { match: /cross-file|consistency/i,
      fix: 'Make the URL sets in /agents.txt and /agents.json agree. The MCP audit_site tool reports which side carries which value.' },
  ];

  function fixHintFor(text: string): FixHint | null {
    // Extract section key from the leading "§X[.Y]: …" prefix.
    const m = text.match(/^§(\d+(?:\.\d+)?)/);
    const sectionKey = m?.[1];
    const phrase = PHRASE_FIXES.find((p) => p.match.test(text));
    if (!sectionKey && !phrase) return null;
    const anchor = sectionKey
      ? (SECTION_TITLES[sectionKey] ?? `§${sectionKey}`)
      : 'Spec';
    const href = sectionKey
      ? `/spec#${sectionKey.replace('.', '')}-${sectionAnchorSlug(SECTION_TITLES[sectionKey] ?? '')}`
      : '/spec';
    const fix = phrase?.fix ?? `Open the spec section for the canonical wording and example.`;
    return { fix, href, anchor };
  }

  // Convert "§4.5 Serving Requirements" → "serving-requirements" for the
  // Astro-generated anchor IDs on /spec.
  function sectionAnchorSlug(title: string): string {
    return title.replace(/^§[\d.]+\s+/, '').toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
  }

  function renderIssue(level: 'error' | 'warning', text: string): string {
    const isErr = level === 'error';
    const glyph = isErr ? '✗' : '!';
    const color = isErr ? '#c00' : '#a16207';
    const hint = fixHintFor(text);
    const hintFix    = hint?.fix    ?? 'Open the agents.txt spec for the canonical wording and example.';
    const hintHref   = hint?.href   ?? '/spec';
    const hintAnchor = hint?.anchor ?? 'Spec';
    const hintBlock = `
          <div class="border border-[#e5e5e5] bg-[#fafafa] px-3 py-2.5">
            <p class="text-[10px] font-semibold uppercase tracking-[0.08em] text-[#999] mb-1">How to fix</p>
            <p class="text-xs text-[#333] leading-relaxed">${escape(hintFix)}</p>
            <p class="mt-2">
              <a href="${escape(hintHref)}" class="font-mono text-[10px] underline underline-offset-2 decoration-[#bbb] hover:decoration-[#111] text-[#111] transition-colors">${escape(hintAnchor)} →</a>
            </p>
          </div>`;
    return `
      <li>
        <details class="audit-issue border border-[#e5e5e5] bg-white">
          <summary class="grid grid-cols-[auto_1fr_auto] gap-x-3 px-3 py-2.5 cursor-pointer hover:bg-[#fafafa] transition-colors items-start">
            <span class="font-mono text-[11px] mt-0.5 shrink-0 w-4" style="color:${color}">${glyph}</span>
            <p class="audit-detail text-xs text-[#333] leading-relaxed min-w-0">${escape(text)}</p>
            <span class="chevron inline-block w-3 text-[#999] text-[10px] mt-0.5 shrink-0">▸</span>
          </summary>
          <div class="px-3 pb-3 pt-0 ml-7">${hintBlock}</div>
        </details>
      </li>
    `;
  }

  function card(heading: string, bodyHtml: string, codeStyleHeading = false): HTMLElement {
    const wrap = document.createElement('div');
    wrap.className = 'border border-[#e5e5e5] mb-4';
    const head = document.createElement('div');
    head.className = 'px-5 py-3 border-b border-[#e5e5e5] bg-[#fafafa]';
    head.innerHTML = codeStyleHeading
      ? `<p class="font-mono text-[11px] font-semibold text-[#111]">${escape(heading)}</p>`
      : `<p class="text-[11px] font-semibold uppercase tracking-[0.08em] text-[#999]">${escape(heading)}</p>`;
    const body = document.createElement('div');
    body.className = 'px-5 py-4';
    body.innerHTML = bodyHtml;
    wrap.appendChild(head);
    wrap.appendChild(body);
    return wrap;
  }

  function escape(s: string): string {
    return s.replace(/[&<>"']/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]!));
  }

  // Initial render from the worker-injected envelope. Placed at the end of
  // the script so that all `const`s referenced by the render path (e.g.
  // SECTION_TITLES, PHRASE_FIXES) are past their temporal dead zone. Bundlers
  // that mangle identifiers would otherwise throw "Cannot access 'X' before
  // initialization" when the pre-rendered branch fires before the consts are
  // reached in source order.
  if (dataEl) {
    try {
      const parsed = JSON.parse(dataEl.textContent ?? '{}');
      if (parsed && typeof parsed === 'object' && 'ok' in parsed) {
        renderEnvelope(parsed as AuditEnvelope);
      }
    } catch {}
  }
</script>
