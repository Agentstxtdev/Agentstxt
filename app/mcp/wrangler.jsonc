{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "agents-txt-mcp",
  "main": "src/index.ts",
  "compatibility_date": "2026-04-01",
  "compatibility_flags": ["nodejs_compat"],

  "vars": {
    "SITE_ORIGIN": "http://localhost:4321"
  },

  // Service binding back to the site worker. Used by audit_site's safeFetch:
  // when an audit target's origin matches SITE_ORIGIN, the fetch routes via
  // env.SITE instead of public `fetch()`. This avoids Cloudflare's edge
  // loop-detection — when site → MCP (service binding) → public fetch back
  // to agents-txt.com (which IS site again), the edge sees a same-account
  // subrequest loop and returns 522. Going worker-to-worker through the
  // binding keeps the chain inside Cloudflare's internal routing and
  // bypasses the loop check.
  "services": [
    { "binding": "SITE", "service": "agents-txt-site-production" }
  ],

  "observability": {
    "enabled": true,
    "logs": { "enabled": true, "head_sampling_rate": 1.0 }
  },

  "durable_objects": {
    "bindings": [{ "class_name": "AgentsTxtMCP", "name": "AgentsTxtMCP" }]
  },

  "migrations": [
    { "new_sqlite_classes": ["AgentsTxtMCP"], "tag": "v1" }
  ],

  "env": {
    "production": {
      "name": "agents-txt-mcp-production",
      "vars": {
        "SITE_ORIGIN": "https://agents-txt.com"
      },
      "durable_objects": {
        "bindings": [{ "class_name": "AgentsTxtMCP", "name": "AgentsTxtMCP" }]
      },
      "migrations": [{ "new_sqlite_classes": ["AgentsTxtMCP"], "tag": "v1" }],
      "services": [
        { "binding": "SITE", "service": "agents-txt-site-production" }
      ],
      "routes": [{ "pattern": "mcp.agents-txt.com", "custom_domain": true }]
    }
  }
}
